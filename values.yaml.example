# A realistic values.yaml shape for nuc-external-secrets.
# Exercise all six supported kinds and show how `generic:` removes repetition.

enabled: true

releasePrefix: external-secrets

commonLabels:
  env: prod
  owner: team-platform
commonAnnotations:
  argocd.argoproj.io/sync-wave: "-1"

generic:
  externalSecret:
    refreshInterval: 1h
    secretStoreRef:
      name: external-secrets-tenant-store
      kind: ClusterSecretStore
    target:
      creationPolicy: Owner
      deletionPolicy: Retain

  pushSecret:
    deletionPolicy: Delete
    refreshInterval: 1h
    secretStoreRefs:
      - name: external-secrets-tenant-store
        kind: ClusterSecretStore

externalSecrets:
  app-config:
    namespace: app
    labels:
      component: external-secret
    annotations:
      note: example
    spec:
      target:
        name: app-config
        template:
          metadata:
            labels:
              synced-by: eso
          data:
            config.yml: |-
              user={{ .username }}
              password={{ .password }}
      data:
        - secretKey: username
          remoteRef:
            key: apps/app-config
            property: username
        - secretKey: password
          remoteRef:
            key: apps/app-config
            property: password

clusterExternalSecrets:
  shared-app-secrets:
    labels:
      component: cluster-external-secret
    annotations:
      note: example
    spec:
      externalSecretName: app-config
      namespaceSelectors:
        - matchLabels:
            eso.nixys.io/sync: enabled
      externalSecretSpec:
        refreshInterval: 30m
        secretStoreRef:
          name: external-secrets-tenant-store
          kind: ClusterSecretStore
        target:
          name: app-config
          creationPolicy: Owner
        data:
          - secretKey: username
            remoteRef:
              key: apps/config
              property: username
          - secretKey: password
            remoteRef:
              key: apps/config
              property: password

secretStores:
  app-store:
    namespace: app
    labels:
      component: secret-store
    annotations:
      note: example
    spec:
      provider:
        fake:
          data:
            - key: username
              value: demo
            - key: password
              value: s3cr3t
      retrySettings:
        maxRetries: 4
        retryInterval: 5s

clusterSecretStores:
  tenant-store:
    labels:
      component: cluster-secret-store
    annotations:
      note: example
    spec:
      provider:
        webhook:
          url: https://eso-provider.example/api/secrets
          headers:
            Content-Type: application/json
          result:
            jsonPath: $.data
      retrySettings:
        maxRetries: 5
        retryInterval: 15s

pushSecrets:
  app-push:
    namespace: app
    labels:
      component: push-secret
    annotations:
      note: example
    spec:
      selector:
        secret:
          name: app-config
      data:
        - match:
            secretKey: config.yml
            remoteRef:
              remoteKey: backups/app-config

clusterPushSecrets:
  shared-push-secret:
    labels:
      component: cluster-push-secret
    annotations:
      note: example
    spec:
      namespaceSelectors:
        - matchLabels:
            eso.nixys.io/push: enabled
      pushSecretSpec:
        refreshInterval: 1h
        secretStoreRefs:
          - name: external-secrets-tenant-store
            kind: ClusterSecretStore
        selector:
          secret:
            name: app-config
        data:
          - match:
              secretKey: config.json
              remoteRef:
                remoteKey: backups/app-config
